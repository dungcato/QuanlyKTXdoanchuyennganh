@model QuanlyKTX.Models.Phong
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Cập nhật Phòng";
}

<style>
    .card-panel {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        padding: 30px;
        border: 1px solid #f1f5f9;
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            font-weight: 600;
            color: #475569;
            font-size: 0.9rem;
            margin-bottom: 8px;
            display: block;
        }

    .form-input {
        width: 100%;
        padding: 12px 15px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        transition: 0.2s;
    }

        .form-input:focus {
            outline: none;
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
        }
</style>

<div style="margin-bottom: 25px; display: flex; align-items: center; gap: 15px;">
    <a href="/Admin/Phong/Index" style="background: white; border: 1px solid #cbd5e1; color: #64748b; padding: 10px 15px; border-radius: 8px; text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 8px;">
        <i data-lucide="arrow-left" style="width: 18px;"></i> Trở lại
    </a>
    <h2 style="font-size: 1.5rem; font-weight: 800; color: #1e293b; margin: 0;">Chỉnh sửa Thông tin Phòng</h2>
</div>

<div class="card-panel">
    @if (TempData["Error"] != null)
    {
        <div style="padding: 15px; margin-bottom: 20px; background: #fee2e2; color: #dc2626; border-radius: 8px; font-weight: 600; display: flex; align-items: center; gap: 8px;">
            <i data-lucide="alert-circle" style="width: 20px;"></i> @TempData["Error"]
        </div>
    }

    <form action="/Admin/Phong/Edit" method="post">

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">

            <div style="background: #f8fafc; padding: 25px; border-radius: 12px; border: 1px solid #e2e8f0;">
                <h4 style="margin-top: 0; color: #4f46e5; font-weight: 800; border-bottom: 2px solid #e0e7ff; padding-bottom: 10px; margin-bottom: 20px;"><i data-lucide="info" style="display: inline-block; vertical-align: text-bottom; width: 20px;"></i> Thông Tin Cơ Bản</h4>

                <div class="form-group">
                    <label>Mã Phòng</label>
                    <input type="text" name="PhongId" value="@Model?.PhongId" readonly class="form-input" style="background: #eef2ff; color: #4f46e5; font-weight: bold; border: 1px dashed #6366f1; cursor: not-allowed;" />
                </div>

                <div class="form-group">
                    <label>Tên Phòng hiển thị <span style="color:red">*</span></label>
                    <input type="text" name="TenPhong" value="@Model?.TenPhong" required class="form-input" />
                </div>

                <div class="form-group">
                    <label>Khu Tòa Nhà <span style="color:red">*</span></label>
                    <select name="ToaNhaId" required class="form-input">
                        @if (ViewBag.ToaNhaList != null)
                        {
                            foreach (var tn in ViewBag.ToaNhaList as List<QuanlyKTX.Models.ToaNha>)
                            {
                                @if (Model?.ToaNhaId == tn.ToaNhaId)
                                {
                                    <option value="@tn.ToaNhaId" selected>Tòa @tn.ToaNhaId</option>
                                }
                                else
                                {
                                    <option value="@tn.ToaNhaId">Tòa @tn.ToaNhaId</option>
                                }
                            }
                        }
                    </select>
                </div>
            </div>

            <div style="background: #fff; padding: 25px; border-radius: 12px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
                <h4 style="margin-top: 0; color: #f59e0b; font-weight: 800; border-bottom: 2px solid #fef3c7; padding-bottom: 10px; margin-bottom: 20px;"><i data-lucide="layers" style="display: inline-block; vertical-align: text-bottom; width: 20px;"></i> Phân Loại & Trạng Thái</h4>

                <div class="form-group">
                    <label>Loại Phòng <span style="color:red">*</span></label>
                    <select name="LoaiPhongId" required class="form-input">
                        @if (ViewBag.LoaiPhongList != null)
                        {
                            foreach (var lp in ViewBag.LoaiPhongList as List<QuanlyKTX.Models.LoaiPhong>)
                            {
                                @if (Model?.LoaiPhongId == lp.LoaiPhongId)
                                {
                                    <option value="@lp.LoaiPhongId" selected>@lp.TenLoai (Sức chứa @lp.SoNguoiToiDa - Giá: @lp.GiaChuan.ToString("N0")đ)</option>
                                }
                                else
                                {
                                    <option value="@lp.LoaiPhongId">@lp.TenLoai (Sức chứa @lp.SoNguoiToiDa - Giá: @lp.GiaChuan.ToString("N0")đ)</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Vị trí Tầng</label>
                    <input type="number" name="Tang" value="@Model?.Tang" class="form-input" />
                </div>

                <div class="form-group" style="margin-top: 20px;">
                    <label>Trạng thái (Khóa phòng bảo trì)</label>
                    <select name="TrangThai" class="form-input" style="font-weight: 700; color: #0f172a;">
                        <!-- Các trạng thái tự nhiên (Đầy/Trống) do hệ thống tự tính dựa vào số lượng người, ở đây chỉ để admin "Cưỡng chế Khóa phòng" đi sửa chữa -->
                        @if (Model?.TrangThai == "Đang bảo trì")
                        {
                            <option value="Còn trống">Đang mở (Hệ thống tự tính chỗ trống)</option>
                            <option value="Đang bảo trì" selected>Khóa phòng (Bảo trì / Tạm ngưng)</option>
                        }
                        else
                        {
                            <option value="Còn trống" selected>Đang mở (Hệ thống tự tính chỗ trống)</option>
                            <option value="Đang bảo trì">Khóa phòng (Bảo trì / Tạm ngưng)</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div style="text-align: right; border-top: 1px solid #f1f5f9; padding-top: 25px; margin-top: 20px;">
            <button type="submit" style="background: #3b82f6; color: white; padding: 12px 40px; font-size: 1.05rem; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; display: inline-flex; align-items: center; gap: 10px; box-shadow: 0 4px 10px rgba(59, 130, 246, 0.3);">
                <i data-lucide="save"></i> Cập Nhật Thông Tin
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>if (typeof lucide !== 'undefined') { lucide.createIcons(); }</script>
}