@model IEnumerable<QuanlyKTX.Models.PhanAnh>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xử lý Phản ánh";

    // CHIA DỮ LIỆU THÀNH 3 CỘT KANBAN
    var lstChoTiepNhan = Model.Where(x => string.IsNullOrEmpty(x.TrangThai) || x.TrangThai == "Chờ tiếp nhận").ToList();
    var lstDangXuLy = Model.Where(x => x.TrangThai == "Đang xử lý").ToList();
    var lstHoanThanh = Model.Where(x => x.TrangThai == "Đã hoàn thành").ToList();
}

<style>
    /* CSS CHO BỘ LỌC */
    .info-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        padding: 20px;
        margin-bottom: 25px;
        border: 1px solid #f1f5f9;
    }

    .info-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 15px;
        font-weight: 800;
        color: #4f46e5;
        font-size: 1.1rem;
    }

    .filter-card {
        display: grid;
        grid-template-columns: 2fr 1fr 1.5fr auto;
        gap: 15px;
        align-items: end;
    }

    .form-group-admin label {
        font-weight: 600;
        color: #475569;
        font-size: 0.85rem;
        margin-bottom: 8px;
        display: block;
    }

    .form-group-admin .input-wrapper {
        position: relative;
    }

        .form-group-admin .input-wrapper i {
            position: absolute;
            left: 12px;
            top: 10px;
            color: #94a3b8;
            width: 18px;
        }

    .form-group-admin input, .form-group-admin select {
        width: 100%;
        padding: 10px 10px 10px 40px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-family: inherit;
    }

    .btn-filter {
        background: #3b82f6;
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .btn-clear {
        background: #f1f5f9;
        color: #475569;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* =========================================
           CSS BẢNG KANBAN BOARD (ĐÃ NÂNG CẤP SCROLL)
           ========================================= */
    .kanban-board-3col {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        align-items: start;
    }

    .kanban-column {
        background: #f8fafc;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        padding: 15px 10px 15px 15px;
        display: flex;
        flex-direction: column;
        height: 75vh;
        min-height: 500px;
    }

    .kanban-column-title {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 800;
        font-size: 1rem;
        padding-bottom: 15px;
        border-bottom: 2px solid #e2e8f0;
        margin-bottom: 15px;
        flex-shrink: 0;
        padding-right: 5px;
    }

        .kanban-column-title.pending {
            color: #f59e0b;
            border-color: #fde68a;
        }

        .kanban-column-title.processing {
            color: #3b82f6;
            border-color: #bfdbfe;
        }

        .kanban-column-title.completed {
            color: #10b981;
            border-color: #a7f3d0;
        }

    .count-badge {
        background: white;
        color: #475569;
        font-size: 0.8rem;
        padding: 2px 10px;
        border-radius: 20px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
    }

    /* CSS KHU VỰC THẺ CÓ THANH CUỘN */
    .kanban-cards {
        display: flex;
        flex-direction: column;
        gap: 15px;
        flex: 1;
        overflow-y: auto;
        padding-right: 8px;
        padding-bottom: 10px;
    }

        .kanban-cards::-webkit-scrollbar {
            width: 6px;
        }

        .kanban-cards::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 10px;
        }

        .kanban-cards::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

            .kanban-cards::-webkit-scrollbar-thumb:hover {
                background: #94a3b8;
            }

    /* CSS THẺ PHẢN ÁNH (CARDS) */
    .issue-card {
        background: white;
        border-radius: 12px;
        padding: 15px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        border: 1px solid #e2e8f0;
        transition: 0.2s;
        position: relative;
    }

        .issue-card:hover {
            border-color: #cbd5e1;
            box-shadow: 0 10px 15px rgba(0,0,0,0.05);
            transform: translateY(-2px);
        }

    .issue-card-header {
        margin-bottom: 12px;
    }

        .issue-card-header .title {
            font-weight: 800;
            color: #1e293b;
            font-size: 0.95rem;
            margin-bottom: 5px;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .issue-card-header .room {
            font-size: 0.8rem;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 5px;
            font-weight: 600;
        }

    .issue-card-student {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 15px;
        padding: 10px;
        background: #f8fafc;
        border-radius: 8px;
    }

        .issue-card-student img {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
        }

        .issue-card-student .name {
            font-size: 0.85rem;
            font-weight: 700;
            color: #334155;
        }

    /* Tag Phân loại */
    .issue-type-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        font-size: 0.7rem;
        font-weight: 800;
        padding: 4px 10px;
        border-radius: 20px;
        text-transform: uppercase;
    }

        .issue-type-badge.dien {
            background: #fee2e2;
            color: #dc2626;
        }

        .issue-type-badge.nuoc {
            background: #e0f2fe;
            color: #0284c7;
        }

        .issue-type-badge.vattu {
            background: #fef3c7;
            color: #d97706;
        }

        .issue-type-badge.khac {
            background: #f1f5f9;
            color: #475569;
        }

    /* Nút Thao tác */
    .issue-card-actions {
        display: flex;
        gap: 8px;
        border-top: 1px dashed #e2e8f0;
        padding-top: 15px;
    }

    .btn-action-card {
        flex: 1;
        border: none;
        padding: 8px 0;
        border-radius: 6px;
        font-weight: 700;
        font-size: 0.8rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        transition: 0.2s;
    }

        .btn-action-card.assign {
            background: #eff6ff;
            color: #3b82f6;
        }

            .btn-action-card.assign:hover {
                background: #3b82f6;
                color: white;
            }

        .btn-action-card.complete {
            background: #ecfdf5;
            color: #10b981;
        }

            .btn-action-card.complete:hover {
                background: #10b981;
                color: white;
            }

        .btn-action-card.view {
            background: #f1f5f9;
            color: #64748b;
            flex: 0.5;
        }

            .btn-action-card.view:hover {
                background: #e2e8f0;
                color: #1e293b;
            }

        .btn-action-card.del {
            background: #fef2f2;
            color: #ef4444;
            flex: 0.3;
        }

            .btn-action-card.del:hover {
                background: #ef4444;
                color: white;
            }

    /* CSS CHO MODAL CHI TIẾT */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(15,23,42,0.6);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(4px);
    }

    .modal-content {
        background: white;
        width: 600px;
        max-width: 90%;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
    }

    .modal-header {
        padding: 20px 25px;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f8fafc;
    }

    .modal-body {
        padding: 25px;
        max-height: 70vh;
        overflow-y: auto;
    }
</style>

<!-- TIÊU ĐỀ TRANG -->
<div style="margin-bottom: 25px;">
    <h2 style="font-size: 1.5rem; font-weight: 800; color: #1e293b; margin: 0 0 5px 0;">Quản lý Phản ánh & Sự cố</h2>
    <p style="color: #64748b; font-size: 0.95rem; margin: 0;">Tiếp nhận, phân công và theo dõi tiến độ xử lý sự cố từ sinh viên.</p>
</div>

<!-- KHỐI 1: BỘ LỌC TÌM KIẾM -->
<div class="info-card">
    <div class="info-header">
        <i data-lucide="search" style="width: 20px;"></i>
        <span>Bộ lọc Phản ánh</span>
    </div>

    <form action="/Admin/PhanAnh/Index" method="get" class="filter-card">
        <!-- Tìm kiếm -->
        <div class="form-group-admin">
            <label>Tìm theo Tên, MSSV, Phòng</label>
            <div class="input-wrapper">
                <i data-lucide="user"></i>
                <input type="text" name="search" value="@ViewBag.Search" placeholder="Nhập từ khóa..." />
            </div>
        </div>

        <!-- Lọc Tòa nhà -->
        <div class="form-group-admin">
            <label>Lọc theo Tòa nhà</label>
            <div class="input-wrapper">
                <i data-lucide="building"></i>
                <select name="searchToaNha">
                    <option value="">Tất cả Tòa</option>
                    @if (ViewBag.ToaNhaList != null)
                    {
                        foreach (var tn in ViewBag.ToaNhaList as List<QuanlyKTX.Models.ToaNha>)
                        {
                            <!-- SỬA CÁCH CHỌN OPTION CHO CHUẨN HTML -->
                            @if (ViewBag.SearchToaNha == tn.ToaNhaId)
                            {
                                <option value="@tn.ToaNhaId" selected>Tòa @tn.ToaNhaId</option>
                            }
                            else
                            {
                                <option value="@tn.ToaNhaId">Tòa @tn.ToaNhaId</option>
                            }
                        }
                    }
                </select>
            </div>
        </div>

        <!-- Lọc Sự cố -->
        <div class="form-group-admin">
            <label>Phân loại sự cố</label>
            <div class="input-wrapper">
                <i data-lucide="alert-triangle"></i>
                <select name="searchLoai">
                    <option value="">Tất cả Loại</option>
                    <!-- SỬA LỖI SELECTED OPTION CHO CHUẨN XÁC 100% -->
                    @if (ViewBag.SearchLoai == "Hỏng Điện")
                    {
                        <option value="Hỏng Điện" selected>Hỏng Điện</option>
                    }
                    else
                    {
                        <option value="Hỏng Điện">Hỏng Điện</option>
                    }
                    @if (ViewBag.SearchLoai == "Hỏng Nước")
                    {
                        <option value="Hỏng Nước" selected>Hỏng Nước</option>
                    }
                    else
                    {
                        <option value="Hỏng Nước">Hỏng Nước</option>
                    }
                    @if (ViewBag.SearchLoai == "Hỏng Vật tư")
                    {
                        <option value="Hỏng Vật tư" selected>Hỏng Vật tư</option>
                    }
                    else
                    {
                        <option value="Hỏng Vật tư">Hỏng Vật tư</option>
                    }
                    @if (ViewBag.SearchLoai == "Khác")
                    {
                        <option value="Khác" selected>Khác</option>
                    }
                    else
                    {
                        <option value="Khác">Khác</option>
                    }
                </select>
            </div>
        </div>

        <!-- Nút Lọc -->
        <div style="display: flex; gap: 10px;">
            <button type="submit" class="btn-filter"><i data-lucide="filter" style="width: 18px;"></i> Lọc</button>
            <a href="/Admin/PhanAnh/Index" class="btn-clear" title="Xóa lọc"><i data-lucide="rotate-ccw" style="width: 18px;"></i></a>
        </div>
    </form>
</div>

<!-- KHỐI 2: BẢNG KANBAN (3 CỘT ĐỘNG) -->
<div class="kanban-board-3col">

    <!-- ================= CỘT 1: CHỜ TIẾP NHẬN ================= -->
    <div class="kanban-column">
        <div class="kanban-column-title pending">
            <span style="display: flex; align-items: center; gap: 8px;"><i data-lucide="inbox" style="width: 20px;"></i> Chờ tiếp nhận</span>
            <span class="count-badge">@lstChoTiepNhan.Count</span>
        </div>
        <div class="kanban-cards">
            @foreach (var item in lstChoTiepNhan)
            {
                // Determine badge class
                string typeClass = "khac";
                if (item.LoaiSuCo == "Hỏng Điện") typeClass = "dien";
                else if (item.LoaiSuCo == "Hỏng Nước") typeClass = "nuoc";
                else if (item.LoaiSuCo == "Hỏng Vật tư") typeClass = "vattu";

                <div class="issue-card" id="card-@item.PhanAnhId">
                    <div class="issue-card-header">
                        <div class="title" title="@item.TieuDe">@item.TieuDe</div>
                        <div class="room"><i data-lucide="door-open" style="width: 14px;"></i> Phòng @(item.PhongId ?? "Chưa rõ") &bull; @(item.NgayGui?.ToString("dd/MM"))</div>
                    </div>

                    <div class="issue-card-student">
                        <img src="https://ui-avatars.com/api/?name=@(item.MssvNavigation?.HoTen ?? "S V")&background=random" alt="Avatar" />
                        <div>
                            <div class="name">@(item.MssvNavigation?.HoTen ?? "Tài khoản bị xóa")</div>
                            <div style="font-size: 0.75rem; color: #94a3b8;">@item.Mssv</div>
                        </div>
                    </div>

                    <span class="issue-type-badge @typeClass">@item.LoaiSuCo</span>

                    <div class="issue-card-actions">
                        <!-- Nút Chuyển sang Đang Xử Lý -->
                        <button type="button" class="btn-action-card assign" onclick="updateStatus(@item.PhanAnhId, 'Đang xử lý')">
                            <i data-lucide="wrench" style="width: 16px;"></i> Tiếp nhận
                        </button>

                        <!-- Nút Xem chi tiết Modal -->
                        <button type="button" class="btn-action-card view" onclick="viewDetail(@item.PhanAnhId)">
                            <i data-lucide="eye" style="width: 16px;"></i>
                        </button>

                        <div id="data-@item.PhanAnhId" style="display: none;"
                             data-title="@item.TieuDe" data-room="@item.PhongId" data-student="@(item.MssvNavigation?.HoTen)" data-ms="@item.Mssv"
                             data-type="@item.LoaiSuCo" data-date="@(item.NgayGui?.ToString("dd/MM/yyyy HH:mm"))" data-content="@item.NoiDung" data-img="@item.HinhAnh">
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ================= CỘT 2: ĐANG XỬ LÝ ================= -->
    <div class="kanban-column">
        <div class="kanban-column-title processing">
            <span style="display: flex; align-items: center; gap: 8px;"><i data-lucide="tool" style="width: 20px;"></i> Đang xử lý</span>
            <span class="count-badge">@lstDangXuLy.Count</span>
        </div>
        <div class="kanban-cards">
            @foreach (var item in lstDangXuLy)
            {
                string typeClass = "khac";
                if (item.LoaiSuCo == "Hỏng Điện") typeClass = "dien";
                else if (item.LoaiSuCo == "Hỏng Nước") typeClass = "nuoc";
                else if (item.LoaiSuCo == "Hỏng Vật tư") typeClass = "vattu";

                <div class="issue-card" id="card-@item.PhanAnhId">
                    <div class="issue-card-header">
                        <div class="title" title="@item.TieuDe">@item.TieuDe</div>
                        <div class="room"><i data-lucide="door-open" style="width: 14px;"></i> Phòng @(item.PhongId ?? "Chưa rõ") &bull; Kỹ thuật đang sửa</div>
                    </div>

                    <div class="issue-card-student">
                        <img src="https://ui-avatars.com/api/?name=@(item.MssvNavigation?.HoTen ?? "S V")&background=random" alt="Avatar" />
                        <div>
                            <div class="name">@(item.MssvNavigation?.HoTen ?? "Tài khoản bị xóa")</div>
                            <div style="font-size: 0.75rem; color: #94a3b8;">@item.Mssv</div>
                        </div>
                    </div>

                    <span class="issue-type-badge @typeClass">@item.LoaiSuCo</span>

                    <div class="issue-card-actions">
                        <!-- Nút Chuyển sang Hoàn thành -->
                        <button type="button" class="btn-action-card complete" onclick="updateStatus(@item.PhanAnhId, 'Đã hoàn thành')">
                            <i data-lucide="check-check" style="width: 16px;"></i> Hoàn tất
                        </button>

                        <button type="button" class="btn-action-card view" onclick="viewDetail(@item.PhanAnhId)">
                            <i data-lucide="eye" style="width: 16px;"></i>
                        </button>

                        <div id="data-@item.PhanAnhId" style="display: none;"
                             data-title="@item.TieuDe" data-room="@item.PhongId" data-student="@(item.MssvNavigation?.HoTen)" data-ms="@item.Mssv"
                             data-type="@item.LoaiSuCo" data-date="@(item.NgayGui?.ToString("dd/MM/yyyy HH:mm"))" data-content="@item.NoiDung" data-img="@item.HinhAnh">
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ================= CỘT 3: ĐÃ HOÀN THÀNH ================= -->
    <div class="kanban-column" style="background: #f1f5f9;">
        <div class="kanban-column-title completed">
            <span style="display: flex; align-items: center; gap: 8px;"><i data-lucide="check-circle" style="width: 20px;"></i> Đã khắc phục</span>
            <span class="count-badge">@lstHoanThanh.Count</span>
        </div>
        <div class="kanban-cards">
            @foreach (var item in lstHoanThanh)
            {
                <div class="issue-card" style="opacity: 0.8;">
                    <div class="issue-card-header">
                        <div class="title" style="text-decoration: line-through; color: #94a3b8;" title="@item.TieuDe">@item.TieuDe</div>
                        <div class="room"><i data-lucide="check-circle-2" style="width: 14px; color: #10b981;"></i> Hoàn thành lúc: @(item.NgayHoanThanh?.ToString("dd/MM"))</div>
                    </div>

                    <div class="issue-card-actions" style="margin-top: 10px; padding-top: 10px;">
                        <button type="button" class="btn-action-card view" style="flex: 1;" onclick="viewDetail(@item.PhanAnhId)">
                            <i data-lucide="file-text" style="width: 16px;"></i> Xem hồ sơ
                        </button>
                        <form action="/Admin/PhanAnh/Delete/@item.PhanAnhId" method="post" style="flex: 0.2; display: flex;" onsubmit="return confirm('Xác nhận xóa hẳn hồ sơ sự cố này?');">
                            <button type="submit" class="btn-action-card del" style="width: 100%;"><i data-lucide="trash-2" style="width: 16px;"></i></button>
                        </form>

                        <div id="data-@item.PhanAnhId" style="display: none;"
                             data-title="@item.TieuDe" data-room="@item.PhongId" data-student="@(item.MssvNavigation?.HoTen)" data-ms="@item.Mssv"
                             data-type="@item.LoaiSuCo" data-date="@(item.NgayGui?.ToString("dd/MM/yyyy HH:mm"))" data-content="@item.NoiDung" data-img="@item.HinhAnh">
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

</div>

<!-- ================= CỬA SỔ XEM CHI TIẾT SỰ CỐ ================= -->
<div class="modal-overlay" id="issueModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 style="margin: 0; font-size: 1.2rem; font-weight: 800; color: #1e293b; display: flex; align-items: center; gap: 8px;">
                <i data-lucide="alert-triangle" style="color: #ef4444;"></i> Hồ sơ Sự cố
            </h3>
            <button type="button" onclick="closeModal()" style="background: #e2e8f0; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #64748b; transition: 0.2s;">
                <i data-lucide="x" style="width: 18px;"></i>
            </button>
        </div>
        <div class="modal-body">
            <h2 id="mTitle" style="margin: 0 0 15px 0; font-size: 1.3rem; color: #0f172a; line-height: 1.4;"></h2>

            <div style="background: #f8fafc; padding: 15px; border-radius: 8px; border: 1px dashed #cbd5e1; margin-bottom: 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; font-size: 0.9rem;">
                <div><b style="color: #475569;">Người báo:</b> <span id="mStudent" style="font-weight: 700; color: #1e293b;"></span> (<span id="mMssv"></span>)</div>
                <div><b style="color: #475569;">Phòng:</b> <span id="mRoom" style="font-weight: 700; color: #3b82f6;"></span></div>
                <div><b style="color: #475569;">Phân loại:</b> <span id="mType" style="font-weight: 700; color: #d97706;"></span></div>
                <div><b style="color: #475569;">Thời gian gửi:</b> <span id="mDate"></span></div>
            </div>

            <div style="margin-bottom: 20px;">
                <h4 style="margin: 0 0 8px 0; font-size: 0.9rem; color: #475569; text-transform: uppercase;">Mô tả chi tiết:</h4>
                <div id="mContent" style="background: #fffbeb; padding: 15px; border-radius: 8px; border-left: 4px solid #f59e0b; color: #334155; line-height: 1.6; white-space: pre-wrap; font-size: 0.95rem;"></div>
            </div>

            <div id="mImageContainer" style="display: none;">
                <h4 style="margin: 0 0 8px 0; font-size: 0.9rem; color: #475569; text-transform: uppercase;">Hình ảnh đính kèm:</h4>
                <div style="border-radius: 8px; overflow: hidden; border: 2px solid #e2e8f0; width: fit-content; max-width: 100%;">
                    <img id="mImage" src="" alt="Hình ảnh sự cố" style="max-width: 100%; max-height: 300px; display: block;" />
                </div>
            </div>
        </div>
        <div style="padding: 15px 25px; background: #f8fafc; border-top: 1px solid #e2e8f0; text-align: right;">
            <button onclick="closeModal()" style="background: #475569; color: white; border: none; padding: 10px 25px; border-radius: 8px; font-weight: 600; cursor: pointer;">Đóng cửa sổ</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        if (typeof lucide !== 'undefined') { lucide.createIcons(); }

        // 1. AJAX CHUYỂN TRẠNG THÁI THẺ KANBAN
        function updateStatus(id, newStatus) {
            // Hiển thị loading nhỏ trên nút
            const card = document.getElementById('card-' + id);
            card.style.opacity = '0.5';

            fetch('/Admin/PhanAnh/CapNhatTrangThai', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    'idPhanAnh': id,
                    'trangThaiMoi': newStatus
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Load lại trang để các cột sắp xếp lại đẹp đẽ
                    window.location.reload();
                } else {
                    alert("Lỗi: " + data.message);
                    card.style.opacity = '1';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert("Đã xảy ra lỗi kết nối!");
                card.style.opacity = '1';
            });
        }

        // 2. LOGIC MODAL XEM CHI TIẾT
        function viewDetail(id) {
            const dataDiv = document.getElementById('data-' + id);

            // Đổ dữ liệu vào Modal
            document.getElementById('mTitle').innerText = dataDiv.getAttribute('data-title');
            document.getElementById('mRoom').innerText = dataDiv.getAttribute('data-room');
            document.getElementById('mStudent').innerText = dataDiv.getAttribute('data-student');
            document.getElementById('mMssv').innerText = dataDiv.getAttribute('data-ms');
            document.getElementById('mType').innerText = dataDiv.getAttribute('data-type');
            document.getElementById('mDate').innerText = dataDiv.getAttribute('data-date');
            document.getElementById('mContent').innerText = dataDiv.getAttribute('data-content');

            const imgUrl = dataDiv.getAttribute('data-img');
            const imgContainer = document.getElementById('mImageContainer');
            if (imgUrl && imgUrl.trim() !== '') {
                document.getElementById('mImage').src = imgUrl;
                imgContainer.style.display = 'block';
            } else {
                imgContainer.style.display = 'none';
            }

            // Hiện modal
            const modal = document.getElementById('issueModal');
            modal.style.display = 'flex';
            modal.style.opacity = 0;
            setTimeout(() => modal.style.opacity = 1, 10); // Fade in effect
        }

        function closeModal() {
            const modal = document.getElementById('issueModal');
            modal.style.opacity = 0;
            setTimeout(() => modal.style.display = 'none', 200);
        }

        // Bấm ra ngoài vùng tối để đóng modal
        document.getElementById('issueModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
    </script>
}