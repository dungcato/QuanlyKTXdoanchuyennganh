@model QuanlyKTX.Models.SinhVien
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Cập nhật Hồ sơ Sinh viên";
}

<div style="margin-bottom: 25px; display: flex; justify-content: space-between; align-items: center;">
    <div style="display: flex; align-items: center; gap: 15px;">
        <a href="/Admin/SinhVien/Index" class="btn-icon" style="background: white; border: 1px solid var(--border); color: var(--text-muted); padding: 8px 12px; border-radius: 8px; text-decoration: none;">
            <i data-lucide="arrow-left" style="width: 18px;"></i> Trở lại
        </a>
        <h2 style="font-size: 1.5rem; font-weight: 800; color: var(--text-main); margin: 0;">Cập nhật Hồ Sơ Sinh Viên</h2>
    </div>
</div>

<div class="info-card" style="border-radius: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); padding: 30px; background: white;">
    <form action="/Admin/SinhVien/Edit" method="post">

        <h4 style="font-size: 14px; font-weight: 700; color: #f59e0b; text-transform: uppercase; margin-bottom: 15px; border-bottom: 2px solid #fef3c7; padding-bottom: 10px;">I. Thông Tin Cá Nhân</h4>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
            <div class="form-group-admin">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Mã Sinh Viên (MSSV) - Khóa chính</label>
                <input type="text" name="Mssv" value="@Model?.Mssv" readonly class="form-control"
                       style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1; background: #f1f5f9; cursor: not-allowed; font-weight: bold; color: #475569;" />
            </div>
            <div class="form-group-admin">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Họ và Tên <span style="color: red">*</span></label>
                <input type="text" name="HoTen" value="@Model?.HoTen" required class="form-control" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1;" />
            </div>
            <div class="form-group-admin">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Ngày sinh</label>
                <input type="date" name="NgaySinh" value="@(Model?.NgaySinh?.ToString("yyyy-MM-dd"))" class="form-control" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1;" />
            </div>
            <div class="form-group-admin">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Giới tính</label>
                <select name="GioiTinh" class="form-control" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1;">
                    <option value="Nam" @(Model?.GioiTinh == "Nam" ? "selected" : "")>Nam</option>
                    <option value="Nữ" @(Model?.GioiTinh == "Nữ" ? "selected" : "")>Nữ</option>
                </select>
            </div>
            <div class="form-group-admin">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Số CCCD</label>
                <input type="text" name="Cccd" value="@Model?.Cccd" class="form-control" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1;" />
            </div>
            <div class="form-group-admin">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Quê quán</label>
                <input type="text" name="QueQuan" value="@Model?.QueQuan" class="form-control" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1;" />
            </div>
        </div>

        <h4 style="font-size: 14px; font-weight: 700; color: #f59e0b; text-transform: uppercase; margin-bottom: 15px; border-bottom: 2px solid #fef3c7; padding-bottom: 10px;">II. Liên Hệ & Đào Tạo</h4>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
            <div class="form-group-admin">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Số điện thoại</label>
                <input type="text" name="Sdt" value="@Model?.Sdt" class="form-control" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1;" />
            </div>
            <div class="form-group-admin">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Email cá nhân</label>
                <input type="email" name="Email" value="@Model?.Email" class="form-control" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1;" />
            </div>
            <div class="form-group-admin">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Lớp</label>
                <input type="text" name="Lop" value="@Model?.Lop" class="form-control" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1;" />
            </div>
            <div class="form-group-admin">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Khoa / Viện</label>
                <input type="text" name="Khoa" value="@Model?.Khoa" class="form-control" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1;" />
            </div>
        </div>

        <h4 style="font-size: 14px; font-weight: 700; color: #f59e0b; text-transform: uppercase; margin-bottom: 15px; border-bottom: 2px solid #fef3c7; padding-bottom: 10px;">III. Lưu Trú & An Ninh</h4>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
            <div class="form-group-admin">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Phòng đang ở</label>
                <select name="PhongDangOid" class="form-control" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1;">
                    <option value="">-- Chưa xếp phòng --</option>
                    @if (ViewBag.PhongList != null)
                    {
                        foreach (var p in ViewBag.PhongList)
                        {
                            <option value="@p.PhongId" @(Model?.PhongDangOid == p.PhongId ? "selected" : "")>Phòng @p.PhongId</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group-admin">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Trạng thái</label>
                <select name="TrangThai" class="form-control" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1;">
                    <option value="Đang lưu trú" @(Model?.TrangThai == "Đang lưu trú" ? "selected" : "")>Đang lưu trú</option>
                    <option value="Chờ xếp phòng" @(Model?.TrangThai == "Chờ xếp phòng" ? "selected" : "")>Chờ xếp phòng</option>
                    <option value="Đã rời đi" @(Model?.TrangThai == "Đã rời đi" ? "selected" : "")>Đã rời đi</option>
                </select>
            </div>

            <div class="form-group-admin" style="grid-column: 1 / -1;">
                <label style="font-weight: 600; margin-bottom: 8px; display: block;">Dữ liệu nhận diện khuôn mặt (FaceID Camera AI)</label>
                <div style="display: flex; gap: 20px; margin-top: 10px; background: #fffbeb; padding: 15px; border-radius: 12px; border: 1px dashed #fcd34d;">
                    <div style="width: 120px; height: 150px; border: 2px solid #fcd34d; border-radius: 8px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: white;">
                        <img id="imgPreview"
                             src="@(!string.IsNullOrEmpty(Model?.FaceIdData) ? Model.FaceIdData : "https://placehold.co/120x150?text=Chưa+có+ảnh")"
                             style="width:100%; height:100%; object-fit: cover;" alt="Preview" />
                    </div>
                    <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; gap: 10px;">
                        <button type="button" onclick="openDialog()"
                                style="background: #f59e0b; color: white; border: none; padding: 10px 20px; border-radius: 8px; width: fit-content; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px;">
                            <i data-lucide="refresh-cw" style="width: 18px;"></i> Đổi ảnh định danh mới
                        </button>
                        <input type="text" id="file_input" name="FaceIdData" value="@Model?.FaceIdData"
                               class="form-control" readonly
                               style="background: white; width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #cbd5e1;" />
                        <p style="font-size: 12px; color: #64748b; margin: 0;">Khuyến nghị: Tỷ lệ ảnh 3x4 hoặc 4x6, rõ khuôn mặt để hệ thống AI nhận diện chính xác.</p>
                    </div>
                </div>
            </div>
        </div>

        <div style="text-align: right; padding-top: 20px; border-top: 1px solid #e2e8f0;">
            <button type="submit" style="background: #f59e0b; color: white; padding: 12px 40px; font-size: 15px; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; display: inline-flex; align-items: center; gap: 8px;">
                <i data-lucide="save" style="width: 18px;"></i> Cập nhật Hồ Sơ
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/admin/lib/snote/jquery.min.js"></script>

        {{-- jQuery UI - dùng CDN cho chắc vì theme smoothness là bắt buộc --}}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.13.2/themes/smoothness/jquery-ui.min.css" />
    <script src="~/admin/lib/jqueryui/jquery-ui.min.js"></script>

    <link rel="stylesheet" href="~/admin/lib/elFinder/css/elfinder.full.css" />
    <link rel="stylesheet" href="~/admin/lib/elFinder/css/theme.min.css" />
    <script src="~/admin/lib/elFinder/js/elfinder.min.js"></script>

    <script>
        if (typeof lucide !== 'undefined') { lucide.createIcons(); }

        function openDialog() {
            $('<div/>').dialogelfinder({
                url: '/Admin/el-finder-file-system/connector',
                baseUrl: '/admin/lib/elFinder/',
                lang: 'vi',
                width: 840,
                height: 500,
                destroyOnClose: true,
                getFileCallback: function (files) {
                    $('#file_input').val(files.url);
                    $('#imgPreview').attr('src', files.url);
                },
                commandsOptions: {
                    getfile: { oncomplete: 'close', folders: false }
                },
                onlyMimes: ['image']
            }).dialogelfinder('instance');
        }
    </script>
}