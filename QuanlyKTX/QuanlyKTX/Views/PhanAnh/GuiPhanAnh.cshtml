@model QuanlyKTX.Models.PhanAnh
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Gửi Phản Ánh";
}

<div class="container-fluid p-0">
    <section class="page-header dashboard-fade-in" style="background: white; border-radius: 20px; padding: 30px; margin-bottom: 30px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08); display: flex; align-items: center; gap: 20px;">
        <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #ff9a8b 0%, #ff6a88 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: white;">
            <i data-lucide="alert-octagon" style="width: 32px; height: 32px;"></i>
        </div>
        <div>
            <h1 style="font-size: 2em; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin: 0; font-weight: 700;">Gửi Phản Ánh</h1>
            <p style="color: #64748b; margin: 0;">Mô tả sự cố bạn đang gặp phải, BQL sẽ hỗ trợ sớm nhất.</p>
        </div>
    </section>

    <section class="quick-select-container dashboard-fade-in delay-1" style="margin-bottom: 25px;">
        <h3 style="font-size: 16px; margin-bottom: 15px;"><i data-lucide="zap" style="color: #eab308; width: 18px;"></i> Vấn đề thường gặp?</h3>
        <div class="quick-tags" style="display: flex; gap: 10px; flex-wrap: wrap;">
            <button type="button" class="quick-tag" style="padding: 8px 15px; border-radius: 20px; border: 1px solid #e2e8f0; background: white; cursor: pointer;"><i data-lucide="lightbulb-off" style="width: 14px;"></i> Hỏng bóng đèn</button>
            <button type="button" class="quick-tag" style="padding: 8px 15px; border-radius: 20px; border: 1px solid #e2e8f0; background: white; cursor: pointer;"><i data-lucide="shower-head" style="width: 14px;"></i> Vòi nước rò rỉ</button>
            <button type="button" class="quick-tag" style="padding: 8px 15px; border-radius: 20px; border: 1px solid #e2e8f0; background: white; cursor: pointer;"><i data-lucide="wifi-off" style="width: 14px;"></i> Wifi yếu / Mất mạng</button>
        </div>
    </section>

    <section class="form-card dashboard-fade-in delay-2" style="background: white; padding: 35px; border-radius: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.02);">
        <form action="/PhanAnh/XuLyPhanAnh" method="POST" enctype="multipart/form-data">
            <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px;">

                <div class="form-group">
                    <label class="form-label" style="font-weight: 600; display: block; margin-bottom: 8px;">Tiêu đề</label>
                    <input type="text" class="form-input" id="titleInput" name="TieuDe" placeholder="Ví dụ: Hỏng bóng đèn bàn học" required style="width: 100%; padding: 12px; border: 1px solid #e2e8f0; border-radius: 10px;">
                </div>

                <div class="form-group">
                    <label class="form-label" style="font-weight: 600; display: block; margin-bottom: 8px;">Phân loại sự cố</label>
                    <select class="form-input" name="LoaiSuCo" required style="width: 100%; padding: 12px; border: 1px solid #e2e8f0; border-radius: 10px;">
                        <option value="">-- Chọn loại sự cố --</option>
                        <option value="Điện">Hỏng hóc về Điện</option>
                        <option value="Nước">Hỏng hóc về Nước</option>
                        <option value="Thiết bị">Hỏng thiết bị</option>
                        <option value="Khác">Khác</option>
                    </select>
                </div>

                <div class="form-group" style="grid-column: 1 / -1;">
                    <label class="form-label" style="font-weight: 600; display: block; margin-bottom: 8px;">Mô tả chi tiết</label>
                    <textarea class="form-textarea" name="NoiDung" required style="width: 100%; padding: 12px; border: 1px solid #e2e8f0; border-radius: 10px; min-height: 120px;"></textarea>
                </div>

                <div class="form-group" style="grid-column: 1 / -1;">
                    <label class="form-label" style="font-weight: 600; display: block; margin-bottom: 8px;">Đính kèm hình ảnh</label>
                    <div class="upload-box" style="border: 2px dashed #cbd5e1; padding: 30px; border-radius: 15px; text-align: center; cursor: pointer;" onclick="document.getElementById('fileUpload').click()">
                        <input type="file" name="HinhAnh" id="fileUpload" hidden accept="image/*">
                        <i data-lucide="upload-cloud" style="width: 40px; height: 40px; color: #94a3b8;"></i>
                        <p id="fileNameDisplay" style="margin-top: 10px; color: #64748b;">Nhấn để chọn ảnh sự cố</p>
                    </div>
                </div>

                <div style="grid-column: 1 / -1; display: flex; justify-content: flex-end;">
                    <button type="submit" class="btn-primary-custom" style="padding: 12px 40px; background: #1e3c72; color: white; border: none; border-radius: 10px; font-weight: 600; cursor: pointer;">
                        <i data-lucide="send" style="width: 18px; vertical-align: middle;"></i> Gửi Phản Ánh
                    </button>
                </div>
            </div>
        </form>
    </section>
</div>

<div class="modal-pa @(TempData["ShowSuccessModal"] != null ? "active" : "")" id="successModal" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: none; align-items: center; justify-content: center; z-index: 9999;">
    <div style="background: white; padding: 40px; border-radius: 20px; text-align: center; max-width: 400px;">
        <i data-lucide="check-circle" style="width: 80px; height: 80px; color: #10b981; margin-bottom: 20px;"></i>
        <h3 style="margin: 0 0 10px 0;">Gửi Thành Công!</h3>
        <p style="color: #64748b; margin-bottom: 25px;">Yêu cầu của bạn đã được gửi đến Ban quản lý.</p>
        <button type="button" onclick="location.reload()" style="width: 100%; padding: 12px; background: #1e3c72; color: white; border: none; border-radius: 10px; cursor: pointer;">Đã hiểu</button>
    </div>
</div>

<style>
    .modal-pa.active {
        display: flex !important;
    }

    .quick-tag:hover {
        border-color: #3b82f6;
        color: #3b82f6;
        background: #eff6ff;
    }
</style>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (typeof lucide !== 'undefined') { lucide.createIcons(); }

            const quickTags = document.querySelectorAll(".quick-tag");
            const titleInput = document.getElementById("titleInput");
            const fileUpload = document.getElementById('fileUpload');
            const fileNameDisplay = document.getElementById('fileNameDisplay');

            quickTags.forEach(tag => {
                tag.addEventListener("click", function () {
                    titleInput.value = this.innerText.trim();
                });
            });

            fileUpload.addEventListener('change', function(e) {
                if(e.target.files.length > 0) {
                    fileNameDisplay.innerText = "Đã chọn: " + e.target.files[0].name;
                }
            });
        });
    </script>
}