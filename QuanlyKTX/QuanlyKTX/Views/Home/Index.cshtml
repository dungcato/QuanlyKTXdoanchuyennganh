@model QuanlyKTX.Models.DashboardViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Trang chủ";
}

<div class="container-fluid p-0">

    <div class="row">
        <div class="col-12">
            <div class="welcome-banner dashboard-fade-in" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); padding: 40px 45px; border-radius: 20px; margin-bottom: 30px; box-shadow: 0 10px 30px rgba(30, 60, 114, 0.2); position: relative; overflow: hidden;">
                <div style="position: absolute; right: 5%; top: -20px; width: 180px; height: 180px; background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 70%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i data-lucide="graduation-cap" class="bg-icon-float" style="width: 90px; height: 90px; color: rgba(255,255,255,0.15);"></i>
                </div>

                <h1 style="color: #ffffff; font-weight: 700; margin-bottom: 15px; font-size: 30px; letter-spacing: 0.5px; display: flex; align-items: center; gap: 12px; position: relative; z-index: 2;">
                    Chào buổi sáng, @Model.SinhVien.HoTen!
                    <i data-lucide="sun" style="color: #fbbf24; width: 34px; height: 34px;"></i>
                </h1>

                <div style="display: flex; gap: 15px; flex-wrap: wrap; position: relative; z-index: 2;">
                    <span style="background: rgba(255,255,255,0.15); backdrop-filter: blur(5px); color: #ffffff; padding: 8px 18px; border-radius: 30px; font-size: 14px; font-weight: 500; display: flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.2);">
                        <i data-lucide="fingerprint" style="width: 16px; height: 16px; color: #93c5fd;"></i>
                        Mã SV: @Model.SinhVien.Mssv
                    </span>
                    <span style="background: rgba(255,255,255,0.15); backdrop-filter: blur(5px); color: #ffffff; padding: 8px 18px; border-radius: 30px; font-size: 14px; font-weight: 500; display: flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.2);">
                        <i data-lucide="map-pin" style="width: 16px; height: 16px; color: #fca5a5;"></i>
                        Phòng: @Model.TenPhong - @Model.TenToa
                    </span>
                    <span style="background: rgba(255,255,255,0.15); backdrop-filter: blur(5px); color: #ffffff; padding: 8px 18px; border-radius: 30px; font-size: 14px; font-weight: 500; display: flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.2);">
                        <i data-lucide="award" style="width: 16px; height: 16px; color: #fde047;"></i>
                        Điểm rèn luyện: 95/100
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="grid-4-cols dashboard-fade-in delay-1" style="margin-bottom: 35px;">
        <div class="stat-card icon-pulse-hover">
            <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #4f46e5;"></div>
            <div class="circle-icon circle-icon-lg" style="background: #e0e7ff; color: #4f46e5;">
                <i data-lucide="wallet" style="width: 30px; height: 30px;"></i>
            </div>
            <div>
                <p style="color: #64748b; font-size: 13px; margin-bottom: 4px; font-weight: 600; text-transform: uppercase;">Số dư ví KTX</p>
                <h3 style="color: #1e293b; margin: 0; font-size: 24px; font-weight: 700; display: flex; align-items: center; gap: 6px;">
                    1,250K <i data-lucide="arrow-up-right" style="color: #10b981; width: 18px; height: 18px;"></i>
                </h3>
            </div>
        </div>

        <div class="stat-card icon-pulse-hover">
            <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #ef4444;"></div>
            <div class="circle-icon circle-icon-lg" style="background: #fee2e2; color: #ef4444;">
                <i data-lucide="receipt" style="width: 30px; height: 30px;"></i>
            </div>
            <div>
                <p style="color: #64748b; font-size: 13px; margin-bottom: 4px; font-weight: 600; text-transform: uppercase;">Hóa đơn tháng này</p>
                <h3 style="color: #ef4444; margin: 0; font-size: 20px; font-weight: 700;">
                    @Model.TongTienHoaDon.ToString("N0") đ
                </h3>
            </div>
        </div>

        <div class="stat-card icon-pulse-hover">
            <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #10b981;"></div>
            <div class="circle-icon circle-icon-lg" style="background: #dcfce7; color: #10b981;">
                <i data-lucide="shield-check" style="width: 30px; height: 30px;"></i>
            </div>
            <div>
                <p style="color: #64748b; font-size: 13px; margin-bottom: 4px; font-weight: 600; text-transform: uppercase;">Trạng thái lưu trú</p>
                <h3 style="color: #1e293b; margin: 0; font-size: 20px; font-weight: 700;">
                    Hợp lệ <span style="font-size: 12px; color: #10b981;">Còn 8T</span>
                </h3>
            </div>
        </div>

        <div class="stat-card icon-pulse-hover">
            <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #f59e0b;"></div>
            <div class="circle-icon circle-icon-lg" style="background: #fef3c7; color: #f59e0b;">
                <i data-lucide="message-square-dashed" style="width: 30px; height: 30px;"></i>
            </div>
            <div>
                <p style="color: #64748b; font-size: 13px; margin-bottom: 4px; font-weight: 600; text-transform: uppercase;">Phản ánh chờ xử lý</p>
                <h3 style="color: #1e293b; margin: 0; font-size: 24px; font-weight: 700;">
                    @Model.SoPhanAnhCho.ToString("D2")
                </h3>
            </div>
        </div>
    </div>

    <div class="grid-2-cols dashboard-fade-in delay-3">
        <div style="background: white; border-radius: 20px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.02);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px;">
                <h3 style="color: #1e293b; margin: 0; font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 10px;">
                    Thông báo mới nhất
                </h3>
            </div>
            <ul style="list-style: none; padding: 0; margin: 0;">
                @foreach (var tb in Model.DanhSachThongBao)
                {
                    <li class="list-item" style="display: flex; gap: 15px; align-items: flex-start; margin-bottom: 15px;">
                        <div class="circle-icon circle-icon-md" style="background: #e0f2fe; color: #0ea5e9;">
                            <i data-lucide="bell" style="width: 20px; height: 20px;"></i>
                        </div>
                        <div style="flex: 1;">
                            <h4 style="margin: 0; font-size: 15px; font-weight: 600; color: #0f172a;">@tb.TieuDe</h4>
                            <p style="margin: 5px 0; font-size: 13px; color: #475569;">@tb.NoiDung</p>
                            <span style="font-size: 12px; color: #94a3b8;">@tb.NgayGui?.ToString("dd/MM/yyyy")</span>
                        </div>
                    </li>
                }
            </ul>
        </div>

        <div style="background: white; border-radius: 20px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.02);">
            <h3 style="color: #1e293b; margin-bottom: 20px; font-size: 18px; font-weight: 700;">Lịch sử nhận diện Cổng</h3>
            <ul style="list-style: none; padding: 0; margin: 0;">
                @foreach (var log in Model.LichSuAnNinh)
                {
                    <li class="list-item" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <div class="circle-icon circle-icon-sm" style="background: #ecfdf5; color: #10b981;">
                                <i data-lucide="log-in" style="width: 16px; height: 16px;"></i>
                            </div>
                            <div>
                                <p style="margin: 0; font-weight: 600; font-size: 14px;">@log.LoaiSuKien</p>
                                <p style="margin: 0; font-size: 12px; color: #64748b;">Xác thực: AI FaceID</p>
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <p style="margin: 0; font-weight: 600;">@log.ThoiGian?.ToString("HH:mm")</p>
                            <p style="margin: 0; font-size: 11px; color: #94a3b8;">@log.ThoiGian?.ToString("dd/MM")</p>
                        </div>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>