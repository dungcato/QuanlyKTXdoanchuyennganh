@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Trang chủ";

    // [BACKEND TƯƠNG LAI] - Móc dữ liệu từ Controller sang
    // var sinhVien = Model.SinhVien;
}

<div class="container-fluid p-0">

    <div class="row">
        <div class="col-12">
            <div class="welcome-banner dashboard-fade-in" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); padding: 40px 45px; border-radius: 20px; margin-bottom: 30px; box-shadow: 0 10px 30px rgba(30, 60, 114, 0.2); position: relative; overflow: hidden;">

                <div style="position: absolute; right: 5%; top: -20px; width: 180px; height: 180px; background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 70%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i data-lucide="graduation-cap" class="bg-icon-float" style="width: 90px; height: 90px; color: rgba(255,255,255,0.15);"></i>
                </div>
                <div style="position: absolute; right: 20%; bottom: -40px; width: 120px; height: 120px; background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 70%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i data-lucide="building-2" style="width: 60px; height: 60px; color: rgba(255,255,255,0.1); transform: rotate(-15deg);"></i>
                </div>

                <h1 style="color: #ffffff; font-weight: 700; margin-bottom: 15px; font-size: 30px; letter-spacing: 0.5px; display: flex; align-items: center; gap: 12px; position: relative; z-index: 2;">
                    Chào buổi sáng, Lê Anh Dũng!
                    <i data-lucide="sun" style="color: #fbbf24; width: 34px; height: 34px;"></i>
                    <i data-lucide="sparkles" style="color: #fcd34d; width: 24px; height: 24px;"></i>
                </h1>

                <div style="display: flex; gap: 15px; flex-wrap: wrap; position: relative; z-index: 2;">
                    <span style="background: rgba(255,255,255,0.15); backdrop-filter: blur(5px); color: #ffffff; padding: 8px 18px; border-radius: 30px; font-size: 14px; font-weight: 500; display: flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.2);">
                        <i data-lucide="fingerprint" style="width: 16px; height: 16px; color: #93c5fd;"></i>
                        Mã SV: 235748020110069
                    </span>
                    <span style="background: rgba(255,255,255,0.15); backdrop-filter: blur(5px); color: #ffffff; padding: 8px 18px; border-radius: 30px; font-size: 14px; font-weight: 500; display: flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.2);">
                        <i data-lucide="map-pin" style="width: 16px; height: 16px; color: #fca5a5;"></i>
                        Phòng: 402 - Tòa A1
                    </span>
                    <span style="background: rgba(255,255,255,0.15); backdrop-filter: blur(5px); color: #ffffff; padding: 8px 18px; border-radius: 30px; font-size: 14px; font-weight: 500; display: flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.2);">
                        <i data-lucide="award" style="width: 16px; height: 16px; color: #fde047;"></i>
                        Điểm rèn luyện KTX: 95/100
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="grid-4-cols dashboard-fade-in delay-1" style="margin-bottom: 35px;">

        <div class="stat-card icon-pulse-hover">
            <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #4f46e5;"></div>
            <div class="circle-icon circle-icon-lg" style="background: #e0e7ff; color: #4f46e5;">
                <i data-lucide="wallet" style="width: 30px; height: 30px;"></i>
            </div>
            <div>
                <p style="color: #64748b; font-size: 13px; margin-bottom: 4px; font-weight: 600; text-transform: uppercase;">Số dư ví KTX</p>
                <h3 style="color: #1e293b; margin: 0; font-size: 24px; font-weight: 700; display: flex; align-items: center; gap: 6px;">
                    1,250K <i data-lucide="arrow-up-right" style="color: #10b981; width: 18px; height: 18px;"></i>
                </h3>
            </div>
        </div>

        <div class="stat-card icon-pulse-hover">
            <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #ef4444;"></div>
            <div class="circle-icon circle-icon-lg" style="background: #fee2e2; color: #ef4444;">
                <i data-lucide="receipt" style="width: 30px; height: 30px;"></i>
            </div>
            <div>
                <p style="color: #64748b; font-size: 13px; margin-bottom: 4px; font-weight: 600; text-transform: uppercase;">Hóa đơn tháng này</p>
                <h3 style="color: #ef4444; margin: 0; font-size: 20px; font-weight: 700; display: flex; align-items: center; gap: 6px;">
                    145,000 đ
                    <i data-lucide="alert-circle" style="width: 18px; height: 18px;" class="icon-ring"></i>
                </h3>
            </div>
        </div>

        <div class="stat-card icon-pulse-hover">
            <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #10b981;"></div>
            <div class="circle-icon circle-icon-lg" style="background: #dcfce7; color: #10b981;">
                <i data-lucide="shield-check" style="width: 30px; height: 30px;"></i>
            </div>
            <div>
                <p style="color: #64748b; font-size: 13px; margin-bottom: 4px; font-weight: 600; text-transform: uppercase;">Trạng thái lưu trú</p>
                <h3 style="color: #1e293b; margin: 0; font-size: 20px; font-weight: 700; display: flex; align-items: center; gap: 6px;">
                    Hợp lệ
                    <span style="font-size: 12px; font-weight: 500; color: #10b981; background: #ecfdf5; padding: 2px 8px; border-radius: 10px;">Còn 8T</span>
                </h3>
            </div>
        </div>

        <div class="stat-card icon-pulse-hover">
            <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #f59e0b;"></div>
            <div class="circle-icon circle-icon-lg" style="background: #fef3c7; color: #f59e0b;">
                <i data-lucide="message-square-dashed" style="width: 30px; height: 30px;"></i>
            </div>
            <div>
                <p style="color: #64748b; font-size: 13px; margin-bottom: 4px; font-weight: 600; text-transform: uppercase;">Phản ánh chờ xử lý</p>
                <h3 style="color: #1e293b; margin: 0; font-size: 24px; font-weight: 700; display: flex; align-items: center; gap: 6px;">
                    02
                    <i data-lucide="clock" style="color: #f59e0b; width: 18px; height: 18px;"></i>
                </h3>
            </div>
        </div>
    </div>

    <div class="dashboard-fade-in delay-2" style="background: white; border-radius: 20px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); margin-bottom: 35px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h3 style="color: #1e293b; margin: 0; font-size: 20px; font-weight: 700; display: flex; align-items: center; gap: 10px;">
                <div class="circle-icon circle-icon-sm" style="background: #eff6ff; color: #3b82f6;">
                    <i data-lucide="layout-grid" style="width: 18px; height: 18px;"></i>
                </div>
                Dịch vụ & Tiện ích
            </h3>
        </div>

        <div class="grid-3-cols">
            <div class="service-card">
                <div class="circle-icon circle-icon-md" style="background: #e0f2fe; color: #0ea5e9;">
                    <i data-lucide="droplets" style="width: 24px; height: 24px;"></i>
                </div>
                <div>
                    <h4 style="font-size: 15px; font-weight: 600; margin-bottom: 4px; color: #1e293b;">Đặt nước uống</h4>
                    <p style="font-size: 12px; color: #64748b; margin: 0;">Giao tận phòng</p>
                </div>
            </div>

            <div class="service-card">
                <div class="circle-icon circle-icon-md" style="background: #fce7f3; color: #ec4899;">
                    <i data-lucide="shirt" style="width: 24px; height: 24px;"></i>
                </div>
                <div>
                    <h4 style="font-size: 15px; font-weight: 600; margin-bottom: 4px; color: #1e293b;">Máy giặt chung</h4>
                    <p style="font-size: 12px; color: #64748b; margin: 0;">Xem tình trạng máy</p>
                </div>
            </div>

            <div class="service-card">
                <div class="circle-icon circle-icon-md" style="background: #ede9fe; color: #8b5cf6;">
                    <i data-lucide="wifi" style="width: 24px; height: 24px;"></i>
                </div>
                <div>
                    <h4 style="font-size: 15px; font-weight: 600; margin-bottom: 4px; color: #1e293b;">Gia hạn Internet</h4>
                    <p style="font-size: 12px; color: #64748b; margin: 0;">Thanh toán gói cước</p>
                </div>
            </div>

            <div class="service-card" onclick="window.location.href='/HoTro/GuiPhanAnh'">
                <div class="circle-icon circle-icon-md" style="background: #fffbeb; color: #f59e0b;">
                    <i data-lucide="wrench" style="width: 24px; height: 24px;"></i>
                </div>
                <div>
                    <h4 style="font-size: 15px; font-weight: 600; margin-bottom: 4px; color: #1e293b;">Báo sửa chữa</h4>
                    <p style="font-size: 12px; color: #64748b; margin: 0;">Điện, nước, cửa, giường</p>
                </div>
            </div>

            <div class="service-card">
                <div class="circle-icon circle-icon-md" style="background: #f3f4f6; color: #475569;">
                    <i data-lucide="luggage" style="width: 24px; height: 24px;"></i>
                </div>
                <div>
                    <h4 style="font-size: 15px; font-weight: 600; margin-bottom: 4px; color: #1e293b;">Khai báo tạm vắng</h4>
                    <p style="font-size: 12px; color: #64748b; margin: 0;">Về quê, đi thực tập</p>
                </div>
            </div>

            <div class="service-card">
                <div class="circle-icon circle-icon-md" style="background: #ecfdf5; color: #10b981;">
                    <i data-lucide="bike" style="width: 24px; height: 24px;"></i>
                </div>
                <div>
                    <h4 style="font-size: 15px; font-weight: 600; margin-bottom: 4px; color: #1e293b;">Đăng ký gửi xe</h4>
                    <p style="font-size: 12px; color: #64748b; margin: 0;">Xe đạp, xe máy điện</p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid-2-cols dashboard-fade-in delay-3">

        <div style="background: white; border-radius: 20px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.02);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px;">
                <h3 style="color: #1e293b; margin: 0; font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 10px;">
                    <div class="circle-icon circle-icon-sm" style="background: #fffbeb;">
                        <i data-lucide="bell-ring" style="width: 18px; height: 18px; color: #f59e0b;" class="icon-ring"></i>
                    </div>
                    Thông báo mới nhất
                </h3>
                <a href="/HoTro/ThongBao" style="color: #3b82f6; text-decoration: none; font-size: 13px; font-weight: 600;">Xem tất cả &rarr;</a>
            </div>

            <ul style="list-style: none; padding: 0; margin: 0;">
                <li class="list-item" style="display: flex; gap: 15px; align-items: flex-start;">
                    <div class="circle-icon circle-icon-md" style="background: #fee2e2; color: #ef4444;">
                        <i data-lucide="zap" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div style="flex: 1;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <h4 style="margin: 0; font-size: 15px; font-weight: 600; color: #0f172a;">Tiền điện nước tháng 10</h4>
                            <span class="status-badge" style="color: #ef4444; background: #fee2e2;">
                                <i data-lucide="circle-alert" style="width: 12px; height: 12px;"></i> Hạn chót
                            </span>
                        </div>
                        <p style="margin: 0 0 8px 0; font-size: 13px; color: #475569; line-height: 1.5;">Vui lòng thanh toán hóa đơn điện nước trước ngày 15/11. Nhấn vào mục Quản lý Hóa đơn để xem chi tiết.</p>
                        <span style="font-size: 12px; color: #94a3b8; display: flex; align-items: center; gap: 5px;"><i data-lucide="clock" style="width: 12px; height: 12px;"></i> 2 giờ trước</span>
                    </div>
                </li>

                <li class="list-item" style="display: flex; gap: 15px; align-items: flex-start;">
                    <div class="circle-icon circle-icon-md" style="background: #e0f2fe; color: #0ea5e9;">
                        <i data-lucide="settings" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div style="flex: 1;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <h4 style="margin: 0; font-size: 15px; font-weight: 600; color: #0f172a;">Bảo trì thang máy Tòa A1</h4>
                            <span class="status-badge" style="color: #0ea5e9; background: #e0f2fe;">Thông tin</span>
                        </div>
                        <p style="margin: 0 0 8px 0; font-size: 13px; color: #475569; line-height: 1.5;">Ban quản lý sẽ bảo trì thang máy số 1 từ 8h-10h sáng ngày mai.</p>
                        <span style="font-size: 12px; color: #94a3b8; display: flex; align-items: center; gap: 5px;"><i data-lucide="calendar" style="width: 12px; height: 12px;"></i> 1 ngày trước</span>
                    </div>
                </li>
            </ul>
        </div>

        <div style="background: white; border-radius: 20px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.02);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px;">
                <h3 style="color: #1e293b; margin: 0; font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 10px;">
                    <div class="circle-icon circle-icon-sm" style="background: #f3e8ff;">
                        <i data-lucide="scan-face" style="width: 18px; height: 18px; color: #a855f7;"></i>
                    </div>
                    Lịch sử nhận diện Cổng
                </h3>
            </div>

            <div style="background: #fafafa; border-radius: 12px; padding: 15px; border: 1px dashed #cbd5e1; margin-bottom: 15px; text-align: center;">
                <i data-lucide="cctv" style="color: #94a3b8; width: 28px; height: 28px; margin-bottom: 8px;"></i>
                <p style="font-size: 13px; color: #64748b; margin: 0;">Hệ thống Camera AI tự động ghi nhận lượt ra/vào KTX của bạn.</p>
            </div>

            <ul style="list-style: none; padding: 0; margin: 0;">
                <li class="list-item" style="display: flex; justify-content: space-between; align-items: center;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div class="circle-icon circle-icon-sm" style="background: #ecfdf5; color: #10b981;">
                            <i data-lucide="log-in" style="width: 16px; height: 16px;"></i>
                        </div>
                        <div>
                            <p style="margin: 0; font-weight: 600; font-size: 14px; color: #1e293b;">Vào cổng chính</p>
                            <p style="margin: 0; font-size: 12px; color: #64748b;">Xác thực: AI FaceID</p>
                        </div>
                    </div>
                    <div style="text-align: right;">
                        <p style="margin: 0; font-weight: 600; font-size: 14px; color: #1e3c72;">18:45</p>
                        <p style="margin: 0; font-size: 11px; color: #94a3b8;">Hôm nay</p>
                    </div>
                </li>

                <li class="list-item" style="display: flex; justify-content: space-between; align-items: center;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div class="circle-icon circle-icon-sm" style="background: #fef2f2; color: #ef4444;">
                            <i data-lucide="log-out" style="width: 16px; height: 16px;"></i>
                        </div>
                        <div>
                            <p style="margin: 0; font-weight: 600; font-size: 14px; color: #1e293b;">Ra cổng chính</p>
                            <p style="margin: 0; font-size: 12px; color: #64748b;">Xác thực: Quẹt thẻ</p>
                        </div>
                    </div>
                    <div style="text-align: right;">
                        <p style="margin: 0; font-weight: 600; font-size: 14px; color: #1e3c72;">06:30</p>
                        <p style="margin: 0; font-size: 11px; color: #94a3b8;">Hôm nay</p>
                    </div>
                </li>
            </ul>

            <div style="text-align: center; margin-top: 15px;">
                <button style="background: white; border: 1px solid #e2e8f0; color: #475569; padding: 6px 16px; border-radius: 20px; font-size: 12px; cursor: pointer; transition: all 0.2s;">Xem đầy đủ lịch sử</button>
            </div>
        </div>
    </div>
</div>