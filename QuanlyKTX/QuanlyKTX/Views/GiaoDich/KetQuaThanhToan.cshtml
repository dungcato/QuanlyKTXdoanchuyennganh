@model QuanlyKTX.Models.VnPaymentResponseModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="max-width: 600px; margin-top: 50px; text-align: center;">
    <div class="card" style="border-radius: 20px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
        @if (Model.VnPayResponseCode == "00")
        {
            <div style="font-size: 80px; color: #10b981;">✔</div>
            <h2 style="color: #064e3b; margin-top: 20px;">Thanh toán thành công!</h2>
            <p style="color: #6b7280;">Hệ thống đã ghi nhận thanh toán cho hóa đơn của bạn.</p>
        }
        else
        {
            <div style="font-size: 80px; color: #ef4444;">✘</div>
            <h2 style="color: #7f1d1d; margin-top: 20px;">Thanh toán thất bại</h2>
            <p style="color: #6b7280;">Giao dịch không thành công hoặc đã bị hủy. Mã lỗi: @Model.VnPayResponseCode</p>
        }

        <hr style="margin: 30px 0; border: none; border-top: 1px dashed #e5e7eb;">

        <div style="text-align: left; background: #f9fafb; padding: 20px; border-radius: 12px;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                <span style="color: #6b7280;">Mã hóa đơn:</span>
                <span style="font-weight: 600;">@Model.OrderId</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                <span style="color: #6b7280;">Mã giao dịch VNPAY:</span>
                <span style="font-weight: 600;">@Model.TransactionId</span>
            </div>
        </div>

        <div style="margin-top: 30px; display: flex; gap: 15px;">
            <a href="@Url.Action("HoaDon", "GiaoDich")" class="btn" style="flex: 1; padding: 12px; background: #4f46e5; color: white; border-radius: 10px; text-decoration: none;">Quay lại Hóa đơn</a>
            <button onclick="window.print()" class="btn" style="flex: 1; padding: 12px; background: #f1f5f9; color: #1e293b; border-radius: 10px; border: none;">In biên lai</button>
        </div>
    </div>
</div>