@model IEnumerable<QuanlyKTX.Models.HoaDon>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Quản lý Hóa đơn";
}

<div class="container-fluid p-0">
    <section class="page-header dashboard-fade-in" style="background: white; border-radius: 20px; padding: 30px; margin-bottom: 30px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08); display: flex; justify-content: space-between; align-items: center;">
        <div class="page-header-content">
            <h1>Quản lý Hóa đơn</h1>
            <p>Kiểm tra, theo dõi và thanh toán hóa đơn hàng tháng của bạn.</p>
        </div>
        <div class="quick-actions-header">
            <button class="btn-header-action btn-history-action"><span>📜</span> Lịch sử</button>
            <button class="btn-header-action btn-export"><span>📤</span> Xuất PDF</button>
        </div>
    </section>

    @if (TempData["ThongBao"] != null)
    {
        <div class="alert alert-info dashboard-fade-in">@TempData["ThongBao"]</div>
    }

    <section class="tabs-container-hd dashboard-fade-in delay-2">
        <h3 class="section-title-hd">Hóa đơn Chưa thanh toán</h3>
        <div class="invoice-cards-grid">
            @foreach (var item in Model.Where(h => h.TrangThai == "Chưa thanh toán"))
            {
                <div class="invoice-card unpaid">
                    <div class="invoice-card-header">
                        <div>
                            <h3 class="invoice-card-title">🧾 Hóa đơn Tháng @item.Thang/@item.Nam</h3>
                            <p class="invoice-month">Mã HĐ: @item.MaHoaDon</p>
                        </div>
                        <span class="status-badge-hd pending">@item.TrangThai</span>
                    </div>
                    <div class="invoice-details">
                        <div class="invoice-row">
                            <span class="invoice-label">Tiền phòng</span>
                            <span class="invoice-value">@item.TienPhong?.ToString("N0")đ</span>
                        </div>
                        <div class="invoice-row">
                            <span class="invoice-label">Tiền điện</span>
                            <span class="invoice-value">@item.TienDien?.ToString("N0")đ</span>
                        </div>
                        <div class="invoice-row">
                            <span class="invoice-label">Tiền nước</span>
                            <span class="invoice-value">@item.TienNuoc?.ToString("N0")đ</span>
                        </div>
                    </div>
                    <div class="invoice-total">
                        <span class="invoice-total-label">Tổng cộng</span>
                        <span class="invoice-total-value">@item.TongTien?.ToString("N0")đ</span>
                    </div>
                    <div class="invoice-actions">
                        <button class="btn-action-hd btn-view-hd"><span>📄</span> Chi tiết</button>
                        <button class="btn-action-hd btn-pay-hd"
                                onclick="openPaymentModal('@item.MaHoaDon', '@item.TongTien?.ToString("N0")')">
                            <span>💳</span> Thanh toán Ngay
                        </button>
                    </div>
                </div>
            }
        </div>

        <h3 class="section-title-hd" style="margin-top:40px;">Lịch sử Thanh toán</h3>
        <div class="payment-history-hd">
            @foreach (var item in Model.Where(h => h.TrangThai == "Đã thanh toán"))
            {
                <div class="history-item-hd">
                    <div class="history-icon-hd" style="background: #dcfce7; color: #16a34a;">✔</div>
                    <div style="flex: 1;">
                        <div class="history-title-hd">Tháng @item.Thang/@item.Nam - @item.MaHoaDon</div>
                        <div class="history-date-hd">Trạng thái: @item.TrangThai</div>
                    </div>
                    <div class="history-amount-hd">@item.TongTien?.ToString("N0")đ</div>
                </div>
            }
        </div>
    </section>
</div>

<div class="modal-qr" id="paymentModal">
    <div class="modal-content-qr">
        <div class="modal-header-qr">
            <h3>Xác nhận Thanh toán</h3>
            <button class="modal-close-qr" onclick="closeModal()">&times;</button>
        </div>
        <div class="modal-body-qr">
            <div class="qr-payment-section">
                <div class="qr-code-container">
                    <div class="bank-logo-hd">VNPAY</div>
                    <p style="margin: 10px 0;">Hóa đơn: <strong id="modalMaHD"></strong></p>
                    <p>Số tiền: <strong id="modalSoTien" style="color: #e11d48; font-size: 1.2rem;"></strong></p>
                    <div class="qr-code-image-hd" style="background: #f8fafc; border: 1px dashed #cbd5e1; padding: 20px;">
                        <i data-lucide="qr-code" style="width: 100px; height: 100px; color: #64748b;"></i>
                        <p style="font-size: 0.8rem; margin-top: 10px;">Quét mã hoặc nhấn nút bên dưới để chuyển tới cổng VNPAY</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-footer-qr" style="display: flex; justify-content: space-between; padding: 20px;">
            <button class="btn-modal-hd secondary" onclick="closeModal()">Quay lại</button>

            <form asp-action="ThanhToanVnPay" asp-controller="GiaoDich" method="post">
                <input type="hidden" name="maHoaDon" id="hiddenMaHD" />
                <button type="submit" class="btn-modal-hd primary" style="background: #4f46e5; color: white;">
                    🚀 Mở Cổng VNPAY TEST
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openPaymentModal(maHD, soTien) {
            document.getElementById("modalMaHD").innerText = maHD;
            document.getElementById("modalSoTien").innerText = soTien + "đ";
            document.getElementById("hiddenMaHD").value = maHD;
            document.getElementById("paymentModal").classList.add("active");
        }

        function closeModal() {
            document.getElementById("paymentModal").classList.remove("active");
        }

        document.addEventListener("DOMContentLoaded", function () {
            if (typeof lucide !== 'undefined') { lucide.createIcons(); }
        });
    </script>
}