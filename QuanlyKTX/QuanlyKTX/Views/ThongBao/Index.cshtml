@model IEnumerable<QuanlyKTX.Models.ThongBao>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Thông báo";
}

<div class="container-fluid p-0">
    <section class="page-header-tb dashboard-fade-in">
        <div class="page-header-icon-tb"><i data-lucide="bell"></i></div>
        <div class="page-header-content-tb">
            <h1>Thông Báo Của Bạn</h1>
            <p>Tất cả cập nhật quan trọng từ Ban Quản lý KTX.</p>
        </div>
    </section>

    <section class="stats-filter-grid dashboard-fade-in delay-1">
        <div class="stat-filter-card all active">
            <div class="stat-filter-icon"><i data-lucide="list"></i></div>
            <div class="stat-filter-label">Tất cả</div>
            <div class="stat-filter-value">@ViewBag.Total</div>
        </div>
        <div class="stat-filter-card unread">
            <div class="stat-filter-icon"><i data-lucide="bell-dot"></i></div>
            <div class="stat-filter-label">Chưa đọc</div>
            <div class="stat-filter-value">@ViewBag.UnreadCount</div>
        </div>
        <div class="stat-filter-card finance">
            <div class="stat-filter-icon"><i data-lucide="receipt"></i></div>
            <div class="stat-filter-label">Tài chính</div>
            <div class="stat-filter-value">@ViewBag.FinanceCount</div>
        </div>
        <div class="stat-filter-card event">
            <div class="stat-filter-icon"><i data-lucide="megaphone"></i></div>
            <div class="stat-filter-label">Sự kiện & Bảo trì</div>
            <div class="stat-filter-value">@ViewBag.EventCount</div>
        </div>
    </section>

    <section class="notification-container dashboard-fade-in delay-2">
        <div class="notification-header">
            <h3><i data-lucide="inbox" style="width: 20px; color: #4f46e5;"></i> Hộp thư Thông báo</h3>
        </div>

        @if (!Model.Any())
        {
            <div style="padding: 40px; text-align: center; color: #94a3b8;">
                <i data-lucide="mail-open" style="width: 48px; height: 48px; margin-bottom: 10px;"></i>
                <p>Bạn không có thông báo nào mới.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                // Xác định class để lọc bằng JS
                string categoryClass = "";
                string iconName = "bell";

                if (item.LoaiThongBao == "Tài chính") { categoryClass = "finance"; iconName = "receipt"; }
                else if (item.LoaiThongBao == "Bảo trì") { categoryClass = "maintenance"; iconName = "wrench"; }
                else { categoryClass = "event"; iconName = "megaphone"; }

                // Giả lập trạng thái unread nếu mới gửi trong 1 ngày
                string unreadClass = (item.NgayGui >= DateTime.Now.AddDays(-1)) ? "unread" : "";

                <div class="notification-item @categoryClass @unreadClass">
                    <div class="notification-icon"><i data-lucide="@iconName"></i></div>
                    <div class="notification-info">
                        <div class="notification-title">@item.TieuDe</div>
                        <div class="notification-description" style="font-size: 14px; color: #475569; margin: 5px 0;">
                            @item.NoiDung
                        </div>
                        <div class="notification-meta">
                            <strong>Loại: @item.LoaiThongBao</strong> | Gửi bởi: @item.NguoiGui | Lúc: @item.NgayGui?.ToString("HH:mm - dd/MM/yyyy")
                        </div>
                        @if (!string.IsNullOrEmpty(item.FileDinhKem))
                        {
                            <a href="@item.FileDinhKem" class="attachment-link" style="font-size: 12px; color: #3b82f6; text-decoration: none; display: block; margin-top: 5px;">
                                <i data-lucide="paperclip" style="width: 12px; vertical-align: middle;"></i> Xem file đính kèm
                            </a>
                        }
                    </div>
                    <div class="unread-dot-wrapper">
                        @if (unreadClass == "unread")
                        {
                            <div class="unread-dot"></div>
                        }
                    </div>
                </div>
            }
        }
    </section>
</div>