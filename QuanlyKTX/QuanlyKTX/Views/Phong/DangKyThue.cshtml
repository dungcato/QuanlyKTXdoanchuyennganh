@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Đăng ký thuê phòng";
}

<div class="container-fluid p-0">

    <div class="page-header dashboard-fade-in">
        <h1>📝 Đăng ký thuê phòng ký túc xá</h1>
        <p>Vui lòng điền đầy đủ và chính xác tất cả thông tin dưới đây</p>
    </div>

    <div class="info-alert dashboard-fade-in delay-1">
        <h4><i data-lucide="info" style="width: 20px; height: 20px;"></i> Lưu ý quan trọng trước khi đăng ký</h4>
        <ul>
            <li>Đăng ký phòng KTX chỉ được thực hiện trong thời gian mở đăng ký (01/08 - 31/08 hàng năm).</li>
            <li>Sinh viên cần chuẩn bị đầy đủ giấy tờ: CMND/CCCD, Giấy xác nhận sinh viên, Ảnh 3x4 khi đến nhận phòng.</li>
            <li>Sau khi gửi đơn, vui lòng chờ phê duyệt từ Ban quản lý (1-3 ngày làm việc).</li>
            <li>Sinh viên có thể theo dõi trạng thái đơn đăng ký tại mục "Quản lý Hóa đơn".</li>
        </ul>
    </div>

    <form action="/Phong/XuLyDangKy" method="POST" class="form-card dashboard-fade-in delay-2">

        <div class="form-section">
            <h2 class="form-section-title">👤 Thông tin cá nhân</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label>Họ và tên <span class="required">*</span></label>
                    <input type="text" class="form-input" name="HoTen" placeholder="Nguyễn Văn A" value="Lê Anh Dũng" required />
                </div>
                <div class="form-group">
                    <label>Mã số sinh viên <span class="required">*</span></label>
                    <input type="text" class="form-input" name="MSSV" placeholder="20210123" value="235748020110069" readonly style="background: #f1f5f9;" />
                </div>
                <div class="form-group">
                    <label>Ngày sinh <span class="required">*</span></label>
                    <input type="date" class="form-input" name="NgaySinh" value="2004-08-15" required />
                </div>
                <div class="form-group">
                    <label>Giới tính <span class="required">*</span></label>
                    <select class="form-input" name="GioiTinh" required>
                        <option value="">-- Chọn giới tính --</option>
                        <option value="Nam" selected>Nam</option>
                        <option value="Nữ">Nữ</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Số điện thoại <span class="required">*</span></label>
                    <input type="tel" class="form-input" name="SDT" value="0987654321" required />
                </div>
                <div class="form-group">
                    <label>Email <span class="required">*</span></label>
                    <input type="email" class="form-input" name="Email" value="235748020110069@student.vinhuni.edu.vn" required />
                </div>
                <div class="form-group">
                    <label>CMND/CCCD <span class="required">*</span></label>
                    <input type="text" class="form-input" name="CCCD" value="040203123456" required />
                </div>
                <div class="form-group">
                    <label>Khoa <span class="required">*</span></label>
                    <select class="form-input" name="Khoa" required>
                        <option value="">-- Chọn khoa --</option>
                        <option value="CNTT" selected>Công nghệ thông tin</option>
                        <option value="KinhTe">Kinh tế</option>
                        <option value="SuPham">Sư phạm</option>
                        <option value="NgoaiNgu">Ngoại ngữ</option>
                    </select>
                </div>
                <div class="form-group" style="grid-column: 1 / -1;">
                    <label>Địa chỉ thường trú <span class="required">*</span></label>
                    <input type="text" class="form-input" name="QueQuan" value="Phường Bến Thủy, TP. Vinh, Nghệ An" required />
                </div>
            </div>
        </div>

        <div class="form-section">
            <h2 class="form-section-title">📞 Thông tin người liên hệ khẩn cấp</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label>Họ tên người liên hệ <span class="required">*</span></label>
                    <input type="text" class="form-input" name="HoTenNguoiThan" placeholder="Họ tên phụ huynh" required />
                </div>
                <div class="form-group">
                    <label>Mối quan hệ <span class="required">*</span></label>
                    <select class="form-input" name="MoiQuanHe" required>
                        <option value="">-- Chọn mối quan hệ --</option>
                        <option value="Cha">Cha</option>
                        <option value="Mẹ">Mẹ</option>
                        <option value="AnhChiEm">Anh/Chị/Em</option>
                        <option value="Khac">Khác</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Số điện thoại liên hệ <span class="required">*</span></label>
                    <input type="tel" class="form-input" name="SDTNguoiThan" placeholder="0912345678" required />
                </div>
            </div>
        </div>

        <div class="form-section">
            <h2 class="form-section-title">🏠 Thông tin đăng ký phòng</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label>Loại phòng <span class="required">*</span></label>
                    <select class="form-input" name="LoaiPhongId" required>
                        <option value="">-- Chọn loại phòng --</option>
                        <option value="1">Phòng 2 người - 1,200,000đ/tháng</option>
                        <option value="2" selected>Phòng 4 người - 800,000đ/tháng</option>
                        <option value="3">Phòng 6 người - 600,000đ/tháng</option>
                        <option value="4">Phòng 8 người - 500,000đ/tháng</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Khu vực ưu tiên <span class="required">*</span></label>
                    <select class="form-input" name="ToaNhaId" required>
                        <option value="">-- Chọn khu vực --</option>
                        <option value="1">Khu A - KTX Nam</option>
                        <option value="2">Khu B - KTX Nam</option>
                        <option value="3">Khu C - KTX Nữ</option>
                        <option value="4">Khu D - KTX Nữ</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Thời gian bắt đầu thuê <span class="required">*</span></label>
                    <input type="date" class="form-input" name="NgayBatDau" required />
                </div>
                <div class="form-group">
                    <label>Thời hạn hợp đồng <span class="required">*</span></label>
                    <select class="form-input" name="ThoiHanThang" required>
                        <option value="">-- Chọn thời hạn --</option>
                        <option value="3">3 tháng</option>
                        <option value="6">6 tháng</option>
                        <option value="9">9 tháng (1 năm học)</option>
                        <option value="12">12 tháng</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-secondary" onclick="window.history.back()">Hủy bỏ</button>
            <button type="submit" class="btn btn-primary">
                <i data-lucide="send" style="width: 18px;"></i> Đăng ký thuê phòng
            </button>
        </div>
    </form>
</div>