@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Đăng ký thuê phòng";
}

<div class="container-fluid p-0">

    <div class="page-header dashboard-fade-in">
        <h1>📝 Đăng ký thuê phòng ký túc xá</h1>
        <p>Vui lòng điền đầy đủ và chính xác tất cả thông tin dưới đây</p>
    </div>

    @if (TempData["ThongBao"] != null)
    {
        <div class="alert @(TempData["ThongBao"].ToString().Contains("Lỗi") ? "alert-danger" : "alert-success") dashboard-fade-in">
            @TempData["ThongBao"]
        </div>
    }

    <div class="info-alert dashboard-fade-in delay-1">
        <h4><i data-lucide="info" style="width: 20px; height: 20px;"></i> Lưu ý quan trọng</h4>
        <ul>
            <li>Sinh viên cần chuẩn bị đầy đủ giấy tờ: CMND/CCCD, Giấy xác nhận sinh viên khi đến nhận phòng.</li>
            <li>Sau khi gửi đơn, vui lòng chờ phê duyệt từ Ban quản lý (1-3 ngày làm việc).</li>
        </ul>
    </div>

    <form action="/Phong/XuLyDangKy" method="POST" class="form-card dashboard-fade-in delay-2">

        <div class="form-section">
            <h2 class="form-section-title">👤 Thông tin cá nhân</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label>Họ và tên <span class="required">*</span></label>
                    <input type="text" class="form-input" name="HoTen" value="Lê Anh Dũng" required />
                </div>
                <div class="form-group">
                    <label>Mã số sinh viên <span class="required">*</span></label>
                    @* name="MSSV" phải viết hoa y hệt tham số trong Controller *@
                    <input type="text" class="form-input" name="MSSV" value="23574801" readonly style="background: #f1f5f9;" />
                </div>
                <div class="form-group">
                    <label>Ngày sinh <span class="required">*</span></label>
                    <input type="date" class="form-input" name="NgaySinh" value="2004-08-15" required />
                </div>
                <div class="form-group">
                    <label>Giới tính <span class="required">*</span></label>
                    <select class="form-input" name="GioiTinh" required>
                        <option value="Nam" selected>Nam</option>
                        <option value="Nữ">Nữ</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="form-section">
            <h2 class="form-section-title">🏠 Thông tin đăng ký phòng</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label>Loại phòng <span class="required">*</span></label>
                    @* value="1", "2"... này sẽ map vào LoaiPhongId trong Controller *@
                    <select class="form-input" name="LoaiPhongId" required>
                        <option value="">-- Chọn loại phòng --</option>
                        <option value="1">Phòng 2 người - 1,200,000đ/tháng</option>
                        <option value="2" selected>Phòng 4 người - 800,000đ/tháng</option>
                        <option value="3">Phòng 6 người - 600,000đ/tháng</option>
                        <option value="4">Phòng 8 người - 500,000đ/tháng</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Thời gian bắt đầu thuê <span class="required">*</span></label>
                    @* name="NgayBatDau" sẽ gửi kiểu string, Controller nhận là DateTime sẽ tự convert *@
                    <input type="date" class="form-input" name="NgayBatDau" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                </div>

                <div class="form-group">
                    <label>Thời hạn hợp đồng <span class="required">*</span></label>
                    @* name="ThoiHanThang" nhận giá trị số nguyên *@
                    <select class="form-input" name="ThoiHanThang" required>
                        <option value="3">3 tháng</option>
                        <option value="6" selected>6 tháng</option>
                        <option value="12">12 tháng</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="form-actions" style="margin-top: 30px; display: flex; gap: 15px; justify-content: flex-end;">
            <button type="button" class="btn-outline-custom" onclick="window.history.back()" style="padding: 10px 25px; border-radius: 10px;">Hủy bỏ</button>
            <button type="submit" class="btn-primary-custom" style="padding: 10px 30px; background: #1e3c72; color: white; border-radius: 10px; border: none; font-weight: 600;">
                <i data-lucide="send" style="width: 18px; vertical-align: middle;"></i> Gửi đơn đăng ký
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (typeof lucide !== 'undefined') { lucide.createIcons(); }
        });
    </script>
}